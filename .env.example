# Environment Variables SMDP Portal

# App / Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-strong-random-secret"

# Local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/smdp_bahteramas?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/smdp_bahteramas?schema=public"

# Local file storage
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"

# Supabase file storage (aktifkan dengan STORAGE_PROVIDER="supabase")
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="documents"
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS="300"

# App settings
MAX_AVATAR_UPLOAD_SIZE_KB="200"
SECURITY_LOG_RETENTION_DAYS="30"
NEXT_PUBLIC_SECURITY_LOG_RETENTION_DAYS="30"

# Local-only PDF export browser path (optional).
# Production serverless export tetap memakai @sparticuz/chromium.
# Windows example:
# PUPPETEER_EXECUTABLE_PATH="C:/Program Files/Google/Chrome/Application/chrome.exe"
